<header>
<p class="tag">🔥 Today's Challenge</p>
<h1>Do one quick review question.</h1>
<p>Keep your study streak alive.</p>
</header>

<div class="container">
<div class="card">
<h2 id="question">Loading...</h2>
<div id="answers"></div>
<p id="result" style="font-size:20px; font-weight:bold;"></p>
<button onclick="newQuestion()">New Question</button>
</div>
</div>

<script>
const questions = [
  {
    question: "What is the slope-intercept form of a line?",
    answers: ["y = mx + b", "a² + b² = c²", "A = πr²"],
    correct: "y = mx + b"
  },
  {
    question: "Which organelle is called the powerhouse of the cell?",
    answers: ["Nucleus", "Mitochondria", "Ribosome"],
    correct: "Mitochondria"
  },
  {
    question: "What does a thesis statement do?",
    answers: ["Gives the main argument", "Ends the essay", "Lists sources"],
    correct: "Gives the main argument"
  },
  {
    question: "When did World War II end?",
    answers: ["1918", "1945", "1962"],
    correct: "1945"
  }
];

let currentQuestion;

function newQuestion() {
  document.getElementById("result").innerText = "";
  currentQuestion = questions[Math.floor(Math.random() * questions.length)];
  document.getElementById("question").innerText = currentQuestion.question;

  let answerHTML = "";
  currentQuestion.answers.forEach(answer => {
    answerHTML += `<button onclick="checkAnswer('${answer}')">${answer}</button><br><br>`;
  });

  document.getElementById("answers").innerHTML = answerHTML;
}

function checkAnswer(answer) {
  if (answer === currentQuestion.correct) {
    document.getElementById("result").innerText = "✅ Correct! Streak kept alive!";
  } else {
    document.getElementById("result").innerText = "❌ Try again!";
  }
}

newQuestion();
</script>

</body>
